{
  "servers": {
    "filesystem": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "enabled": true,
      "timeout": 30
    },
    "sqlite": {
      "transport": "stdio",
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "data.db"],
      "enabled": false,
      "timeout": 30
    },
    "web-search": {
      "transport": "sse",
      "url": "http://localhost:3001/sse",
      "enabled": false,
      "timeout": 60
    },
    "notion": {
      "_comment": "Notion remote MCP — uses OAuth 2.1 with Dynamic Client Registration (no client_id needed). Run: omlx mcp login notion",
      "transport": "streamable-http",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false,
      "timeout": 60,
      "auth": {
        "type": "oauth2"
      }
    },
    "notion-oauth-app": {
      "_comment": "Notion public OAuth app — for developers with a registered OAuth application (client_id required)",
      "transport": "streamable-http",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false,
      "timeout": 60,
      "auth": {
        "type": "oauth2",
        "client_id": "YOUR_NOTION_OAUTH_CLIENT_ID",
        "auth_url": "https://api.notion.com/v1/oauth/authorize",
        "token_url": "https://api.notion.com/v1/oauth/token",
        "scopes": ["read_content", "update_content"]
      }
    }
  },
  "max_tool_calls": 10,
  "default_timeout": 30.0
}
